# ============================================================================
# Пример конфигурации.
#
# ПРАВИЛО: комментарий пишем ТОЛЬКО на отдельной строке над переменной.
# ============================================================================


# БАЗА ДАННЫХ ----------------------------------------------------------------

# Эти три переменные читает КОНТЕЙНЕР Postgres при первом запуске:
POSTGRES_USER=hookline
POSTGRES_PASSWORD=hookline_dev_pass
POSTGRES_DB=hookline
# Порт локального устройсва
POSTGRES_PORT=5433
# Вариант для локального запуска.
DATABASE_URL=postgres://hookline:hookline_dev_pass@localhost:5433/hookline?sslmode=disable
# Размер пула соединений с БД.
DB_MAX_CONNS=10


# HTTP-СЕРВЕР -----------------------------------------------------------------

# Порт API и дашборда.
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
# Сколько ждём завершения запросов при остановке (graceful shutdown).
HTTP_SHUTDOWN_TIMEOUT=15s


# РЕЖИМ ЗАПУСКА -----------------------------------------------------------------

# api    — только HTTP-сервер
# worker — только воркеры доставки
# all    — и то и другое в одном процессе
APP_MODE=all
# debug | info | warn | error
LOG_LEVEL=debug
# text — локально; json — для прода
LOG_FORMAT=text


# ВОРКЕРЫ И ОЧЕРЕДЬ --------------------------------------------------------------

# Горутины-воркеры в одном процессе:
WORKER_POOL_SIZE=5
# Сообщения воркеры забирают из очереди:
WORKER_BATCH_SIZE=10
# Пауза, если очередь пуста — чтобы не долбить базу впустую.
WORKER_POLL_INTERVAL=1s
# "Бронь" на сообщение: на сколько оно резервируется за воркером.
QUEUE_LEASE_DURATION=30s
# Как часто "жнец" возвращает в очередь сообщения с протухшей бронью.
# !!! Не меньше QUEUE_LEASE_DURATION.
QUEUE_REAPER_INTERVAL=15s


# ДОСТАВКА -----------------------------------------------------------------

# Таймаут одного HTTP-запроса подписчику.
DELIVERY_TIMEOUT=10s
# Сколько байт ответа читаем максимум (1 МБ).
DELIVERY_MAX_RESPONSE_BYTES=1048576
# Сколько байт ответа сохраняем в журнал попыток (1 КБ).
DELIVERY_BODY_SNIPPET_BYTES=1024
# Чем представляемся получателю.
DELIVERY_USER_AGENT=Hookline/1.0


# РЕТРАИ (backoff) -----------------------------------------------------------

# Задержка перед следующей попыткой: base * 2^attempt, но не больше max,
# затем full jitter — случайное значение от 0 до полученной задержки.
RETRY_BASE_DELAY=5s
RETRY_MAX_DELAY=6h
# После исчерпания попыток сообщение уходит в DLQ (status=dead).
RETRY_MAX_ATTEMPTS=8


# CIRCUIT BREAKER (защита лежачих получателей)--------------------------------

# Сколько неудач подряд до размыкания.
BREAKER_FAILURE_THRESHOLD=10
# На сколько размыкаем в первый раз.
BREAKER_OPEN_DURATION=5m
# Потолок при удвоении.
BREAKER_MAX_OPEN_DURATION=1h


# ----------------------------------------------------------------------------
# ПОДПИСЬ ИСХОДЯЩИХ ЗАПРОСОВ
# ----------------------------------------------------------------------------

# Время жизни запроса
SIGNATURE_TOLERANCE=5m


# ЛИМИТЫ -----------------------------------------------------------

# Запросов в секунду на один эндпоинт по умолчанию.
DEFAULT_ENDPOINT_RATE_LIMIT=5
# Максимальный размер входящего события (256 КБ).
INGEST_MAX_BODY_BYTES=262144


# ТЕСТОВЫЙ ПРИЁМНИК (cmd/sink) ------------------------------------------------

SINK_PORT=9090
