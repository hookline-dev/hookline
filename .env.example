# ============================================================================
# Пример конфигурации.
#
# ПРАВИЛО: комментарий пишем ТОЛЬКО на отдельной строке над переменной.
# ============================================================================


# БАЗА ДАННЫХ ----------------------------------------------------------------

POSTGRES_USER=hookline
POSTGRES_PASSWORD=hookline_dev_pass
POSTGRES_DB=hookline
POSTGRES_PORT=5433
DATABASE_URL=postgres://hookline:hookline_dev_pass@localhost:5433/hookline?sslmode=disable
DB_MAX_CONNS=10


# HTTP-СЕРВЕР -----------------------------------------------------------------

HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=15s


# РЕЖИМ ЗАПУСКА -----------------------------------------------------------------

# api    — только HTTP-сервер
# worker — только воркеры доставки
# all    — и то и другое в одном процессе
APP_MODE=all
# debug | info | warn | error
LOG_LEVEL=debug
# text — локально; json — для прода
LOG_FORMAT=text


# ВОРКЕРЫ И ОЧЕРЕДЬ --------------------------------------------------------------

WORKER_POOL_SIZE=5
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL=1s
QUEUE_LEASE_DURATION=30s
QUEUE_REAPER_INTERVAL=15s


# ДОСТАВКА -----------------------------------------------------------------

DELIVERY_TIMEOUT=10s
DELIVERY_MAX_RESPONSE_BYTES=1048576
DELIVERY_BODY_SNIPPET_BYTES=1024
DELIVERY_USER_AGENT=Hookline/1.0


# РЕТРАИ (backoff) -----------------------------------------------------------

RETRY_BASE_DELAY=5s
RETRY_MAX_DELAY=6h
RETRY_MAX_ATTEMPTS=8


# CIRCUIT BREAKER (защита лежачих получателей)--------------------------------

BREAKER_FAILURE_THRESHOLD=10
BREAKER_OPEN_DURATION=5m
BREAKER_MAX_OPEN_DURATION=1h


# ПОДПИСЬ ИСХОДЯЩИХ ЗАПРОСОВ --------------------------------------------------

SIGNATURE_TOLERANCE=5m


# ЛИМИТЫ -----------------------------------------------------------

DEFAULT_ENDPOINT_RATE_LIMIT=5
INGEST_MAX_BODY_BYTES=262144


# ТЕСТОВЫЙ ПРИЁМНИК (cmd/sink) ------------------------------------------------

SINK_PORT=9090

